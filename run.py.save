from ai_logic.voice import speak, listen
from ai_logic.chatbot import get_response

print("🎤 Voice AI started (type 'exit' to stop)\n")

while True:

    user_input = listen()

    if not user_input:
        continue

    if user_input.lower() == "exit":
        speak("Goodbye!")
        break

    response = get_response(user_input)

    speak(response)